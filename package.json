{
    "name": "plexcord",
    "private": "true",
    "version": "1.21.3",
    "description": "Taking Discord to the Next Level!",
    "homepage": "https://github.com/MutanPlex/Plexcord#readme",
    "bugs": {
        "url": "https://github.com/MutanPlex/Plexcord/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MutanPlex/Plexcord.git"
    },
    "license": "GPL-3.0-or-later",
    "author": "MutanPlex",
    "scripts": {
        "build": "pnpm depCheck && node --require=./scripts/suppressExperimentalWarnings.js scripts/build/build.mjs",
        "buildStandalone": "pnpm build --standalone",
        "buildWeb": "pnpm depCheck && node --require=./scripts/suppressExperimentalWarnings.js scripts/build/buildWeb.mjs",
        "buildWebStandalone": "pnpm buildWeb --standalone",
        "buildReporter": "pnpm buildWebStandalone --reporter --skip-extension",
        "buildReporterDesktop": "pnpm build --reporter",
        "watch": "pnpm build --watch",
        "dev": "pnpm watch",
        "watchWeb": "pnpm buildWeb --watch",
        "generatePluginJson": "tsx scripts/generatePluginList.ts",
        "generateTypes": "tspc --emitDeclarationOnly --declaration --outDir packages/plexcord-types --allowJs false",
        "inject": "node scripts/runInstaller.mjs -- --install",
        "uninject": "node scripts/runInstaller.mjs -- --uninstall",
        "repair": "node scripts/runInstaller.mjs -- --repair",
        "lint": "eslint",
        "lint-styles": "stylelint \"src/**/*.css\" --ignore-pattern src/userplugins",
        "lint:fix": "pnpm lint --fix",
        "test": "pnpm buildStandalone && pnpm testTsc && pnpm lint:fix && pnpm lint-styles && pnpm generatePluginJson",
        "testWeb": "pnpm lint:fix && pnpm buildWeb && pnpm testTsc",
        "testTsc": "tsc --noEmit",
        "depCheck": "node scripts/depCheck.mjs"
    },
    "dependencies": {
        "@ffmpeg/ffmpeg": "^0.12.10",
        "@ffmpeg/util": "^0.12.1",
        "@intrnl/xxhash64": "^0.1.2",
        "@streamparser/json": "^0.0.22",
        "@types/less": "^3.0.8",
        "@types/stylus": "^0.48.42",
        "@types/tinycolor2": "^1.4.6",
        "@vap/core": "0.0.12",
        "@vap/shiki": "0.10.5",
        "fflate": "^0.8.2",
        "gifenc": "github:mattdesl/gifenc#64842fca317b112a8590f8fef2bf3825da8f6fe3",
        "idb": "^8.0.3",
        "jsqr": "^1.4.0",
        "monaco-editor": "^0.55.1",
        "nanoid": "^5.1.7",
        "native-file-system-adapter": "^3.0.1",
        "p-limit": "^7.3.0",
        "usercss-meta": "^0.12.0",
        "virtual-merge": "^1.0.2",
        "zip-local": "^0.3.5"
    },
    "devDependencies": {
        "@electron/asar": "^4.2.0",
        "@plexcord/discord-types": "link:packages\\discord-types",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/chrome": "^0.1.40",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/yazl": "^3.3.1",
        "diff": "^8.0.4",
        "esbuild": "^0.28.0",
        "eslint": "10.2.0",
        "eslint-import-resolver-alias": "^1.1.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-simple-header": "^1.2.2",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "highlight.js": "11.11.1",
        "html-minifier-terser": "^7.2.0",
        "jszip": "^3.10.1",
        "moment": "^2.30.1",
        "puppeteer-core": "^24.40.0",
        "standalone-electron-types": "^34.2.0",
        "stylelint": "^17.7.0",
        "stylelint-config-standard": "^40.0.0",
        "ts-patch": "^3.3.0",
        "ts-pattern": "^5.9.0",
        "tsx": "^4.21.0",
        "type-fest": "^5.5.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1",
        "typescript-transform-paths": "^3.5.6"
    },
    "packageManager": "pnpm@10.32.1",
    "pnpm": {
        "patchedDependencies": {
            "@types/less@3.0.8": "patches/@types__less@3.0.8.patch",
            "standalone-electron-types@34.2.0": "patches/standalone-electron-types@34.2.0.patch"
        },
        "peerDependencyRules": {
            "ignoreMissing": [
                "eslint-plugin-import",
                "eslint"
            ]
        },
        "allowedDeprecatedVersions": {
            "source-map-resolve": "*",
            "resolve-url": "*",
            "source-map-url": "*",
            "urix": "*",
            "q": "*"
        },
        "onlyBuiltDependencies": [
            "esbuild"
        ],
        "overrides": {
            "@types/react": "19.2.14",
            "@types/react-dom": "19.2.3",
            "jszip": "^3.10.1",
            "dompurify": "^3.3.2",
            "@eslint/plugin-kit@<0.3.4": ">=0.3.4",
            "@isaacs/brace-expansion": ">=6.0.0",
            "minimatch": ">=10.2.3",
            "basic-ftp": ">=5.2.2",
            "flatted": ">=3.4.0",
            "picomatch@>=4.0.0<4.0.4": ">=4.0.4",
            "picomatch@<2.3.2": ">=2.3.2",
            "picomatch": ">=4.0.4"
        }
    },
    "engines": {
        "node": ">=18"
    }
}
